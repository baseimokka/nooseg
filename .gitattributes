# Normalize line endings: store everything as LF in the repo so the Linux
# VPS deployment always gets Unix line endings regardless of the OS used to commit.
* text=auto eol=lf

# Binary assets — never touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.avif  binary
*.ico   binary
*.otf   binary
*.ttf   binary
*.woff  binary
*.woff2 binary
