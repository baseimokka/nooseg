PORT=3000

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=noos_store
DB_USER=root
DB_PASSWORD=change_me

# Auth — MUST be a strong random string (>= 32 chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_random_secret_at_least_32_chars_long

# Meta (Facebook) Pixel + Conversions API
# META_PIXEL_ID is also embedded in frontend/js/pixel.js (public). The token is
# server-only and must never reach the client.
META_PIXEL_ID=
META_CAPI_TOKEN=
# Optional: a Test Events code from Events Manager while verifying; clear for prod.
META_TEST_EVENT_CODE=
